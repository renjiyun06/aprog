#!/usr/bin/env bun
//
// render <exec-dir> <output-dir>
//
// Reads the canonical brief state from <exec-dir>/state/ and renders a
// single-page HTML tree to <output-dir>/index.html.
//
//   inputs (under <exec-dir>/state/):
//     vision                — md
//     modules               — yaml list
//     processes/<mod-id>    — yaml list (one file per module)
//     details/<proc-id>.md  — md (one file per detailed process)
//     coverage              — yaml mapping <proc-id> → detailed|deferred|skipped|todo
//
//   output:
//     <output-dir>/index.html — self-contained, embedded CSS, no external assets
//
// Every renderable node carries a data-shape-node attribute so future
// versions of the live-annotate overlay can resolve a comment to the
// canonical state file even if the CSS selector drifts.
//
// Re-run on every state write that should be visible to the user. Cheap.

import { readFileSync, writeFileSync, existsSync, statSync, readdirSync, mkdirSync } from "fs";
import { join, resolve } from "path";

const args = process.argv.slice(2);
if (args.length < 2) {
  console.error("Usage: render <exec-dir> <output-dir>");
  process.exit(1);
}
const execDir = resolve(args[0]);
const outDir = resolve(args[1]);
if (!existsSync(execDir) || !statSync(execDir).isDirectory()) {
  console.error(`exec-dir does not exist or is not a directory: ${execDir}`);
  process.exit(1);
}
mkdirSync(outDir, { recursive: true });

const stateDir = join(execDir, "state");

// ---------------------------------------------------------------------------
// Tiny YAML subset parser. Handles:
//   - sequences of scalars OR sequences of mappings
//   - mappings of scalar values
//   - nested sequences (- item) under a mapping key
//   - nested mappings under a list item (the "- key: ..." pattern)
//   - scalars: unquoted strings (trimmed), numbers, booleans (true/false), null
//   - "key: |"  multi-line block scalars (folded as paragraphs)
//
// Does NOT handle: anchors, tags, flow style ({}, []), >, complex keys.
// If the schema we use ever needs more, this parser grows — or we switch to
// a real YAML lib. For shape v0.1 this subset is enough.
// ---------------------------------------------------------------------------
type YAMLValue = string | number | boolean | null | YAMLValue[] | { [k: string]: YAMLValue };

function parseYAML(text: string): YAMLValue {
  const lines = text.replace(/\r\n/g, "\n").split("\n");
  // Strip trailing whitespace; preserve indent; drop pure-comment lines and blanks.
  type Line = { indent: number; raw: string; n: number };
  const all: Line[] = [];
  for (let i = 0; i < lines.length; i++) {
    const l = lines[i];
    const stripped = l.replace(/\s+$/, "");
    if (!stripped.trim()) { all.push({ indent: -1, raw: "", n: i }); continue; }
    if (stripped.trimStart().startsWith("#")) continue;
    const indent = stripped.length - stripped.trimStart().length;
    all.push({ indent, raw: stripped, n: i });
  }
  // Drop leading/trailing blanks for the cursor walk; keep them in `all` for block-scalar lookups.
  let cursor = 0;
  while (cursor < all.length && all[cursor].indent === -1) cursor++;
  if (cursor >= all.length) return null;

  function parseScalar(s: string): YAMLValue {
    const t = s.trim();
    if (t === "" || t === "~" || t === "null") return null;
    if (t === "true") return true;
    if (t === "false") return false;
    if (/^-?\d+$/.test(t)) return parseInt(t, 10);
    if (/^-?\d+\.\d+$/.test(t)) return parseFloat(t);
    // strip matching quotes
    if ((t.startsWith('"') && t.endsWith('"')) || (t.startsWith("'") && t.endsWith("'"))) {
      return t.slice(1, -1);
    }
    return t;
  }

  function readBlockScalar(parentIndent: number, startIdx: number): { value: string; nextIdx: number } {
    // After `key: |` or `- key: |` — gather indented lines below as paragraphs.
    const out: string[] = [];
    let idx = startIdx;
    while (idx < all.length) {
      const l = all[idx];
      if (l.indent === -1) { out.push(""); idx++; continue; }
      if (l.indent <= parentIndent) break;
      out.push(l.raw.slice(parentIndent + 2));
      idx++;
    }
    // trim trailing blanks
    while (out.length && out[out.length - 1] === "") out.pop();
    return { value: out.join("\n"), nextIdx: idx };
  }

  function nextNonBlank(idx: number): number {
    while (idx < all.length && all[idx].indent === -1) idx++;
    return idx;
  }

  function parseValue(indent: number, startIdx: number): { value: YAMLValue; nextIdx: number } {
    let idx = nextNonBlank(startIdx);
    if (idx >= all.length) return { value: null, nextIdx: idx };
    const first = all[idx];
    if (first.indent < indent) return { value: null, nextIdx: idx };
    const text = first.raw.slice(first.indent);
    // Sequence?
    if (text.startsWith("- ") || text === "-") {
      return parseSequence(indent, idx);
    }
    // Mapping
    return parseMapping(indent, idx);
  }

  function parseSequence(indent: number, startIdx: number): { value: YAMLValue[]; nextIdx: number } {
    const out: YAMLValue[] = [];
    let idx = startIdx;
    while (idx < all.length) {
      idx = nextNonBlank(idx);
      if (idx >= all.length) break;
      const l = all[idx];
      if (l.indent < indent) break;
      if (l.indent > indent) break; // not at our level
      const text = l.raw.slice(l.indent);
      if (!text.startsWith("-")) break;

      const after = text === "-" ? "" : text.slice(2);
      idx++;
      if (after === "") {
        // value lives in indented lines below
        const { value, nextIdx } = parseValue(indent + 2, idx);
        out.push(value);
        idx = nextIdx;
      } else if (after.includes(":") && !after.startsWith("\"") && !after.startsWith("'")) {
        // "- key: value" — inline mapping start; treat the "- " column as the mapping's indent
        const mapIndent = l.indent + 2;
        const inlineLine: Line = { indent: mapIndent, raw: " ".repeat(mapIndent) + after, n: l.n };
        // splice the synthetic line back in
        all.splice(idx, 0, inlineLine);
        const { value, nextIdx } = parseMapping(mapIndent, idx);
        out.push(value);
        idx = nextIdx;
      } else {
        out.push(parseScalar(after));
      }
    }
    return { value: out, nextIdx: idx };
  }

  function parseMapping(indent: number, startIdx: number): { value: { [k: string]: YAMLValue }; nextIdx: number } {
    const out: { [k: string]: YAMLValue } = {};
    let idx = startIdx;
    while (idx < all.length) {
      idx = nextNonBlank(idx);
      if (idx >= all.length) break;
      const l = all[idx];
      if (l.indent < indent) break;
      if (l.indent > indent) break;
      const text = l.raw.slice(l.indent);
      if (text.startsWith("- ") || text === "-") break;
      const colon = text.indexOf(":");
      if (colon < 0) { idx++; continue; }
      const key = text.slice(0, colon).trim();
      const rest = text.slice(colon + 1).trim();
      idx++;
      if (rest === "|") {
        const { value, nextIdx } = readBlockScalar(l.indent, idx);
        out[key] = value;
        idx = nextIdx;
      } else if (rest === "") {
        const { value, nextIdx } = parseValue(indent + 2, idx);
        out[key] = value;
        idx = nextIdx;
      } else {
        out[key] = parseScalar(rest);
      }
    }
    return { value: out, nextIdx: idx };
  }

  const { value } = parseValue(0, cursor);
  return value;
}

function readYAMLFile(p: string): YAMLValue {
  if (!existsSync(p)) return null;
  try { return parseYAML(readFileSync(p, "utf-8")); }
  catch (e) { console.error(`render: failed to parse ${p}: ${e}`); return null; }
}

// ---------------------------------------------------------------------------
// Tiny Markdown subset → HTML.  ##, ###, ####  • paragraphs  •  bullet lists
// (- or *)  •  numbered lists  •  **bold**  •  *em*  •  `code`  •  fenced ```code```
// Escapes HTML in scalar text. No tables, no images, no links beyond <a href>.
// ---------------------------------------------------------------------------
function escapeHTML(s: string): string {
  return s.replace(/[&<>"']/g, (c) => (
    c === "&" ? "&amp;" :
    c === "<" ? "&lt;" :
    c === ">" ? "&gt;" :
    c === '"' ? "&quot;" : "&#39;"
  ));
}

function renderInline(s: string): string {
  let out = escapeHTML(s);
  out = out.replace(/`([^`]+)`/g, (_, c) => `<code>${c}</code>`);
  out = out.replace(/\*\*([^*]+)\*\*/g, (_, c) => `<strong>${c}</strong>`);
  out = out.replace(/(?<!\*)\*(?!\*)([^*]+)\*(?!\*)/g, (_, c) => `<em>${c}</em>`);
  return out;
}

function renderMD(md: string): string {
  const lines = md.replace(/\r\n/g, "\n").split("\n");
  const out: string[] = [];
  let i = 0;
  while (i < lines.length) {
    const l = lines[i];
    // fenced code
    if (/^```/.test(l)) {
      const lang = l.replace(/^```/, "").trim();
      const buf: string[] = [];
      i++;
      while (i < lines.length && !/^```/.test(lines[i])) { buf.push(lines[i]); i++; }
      if (i < lines.length) i++; // skip closing fence
      const code = escapeHTML(buf.join("\n"));
      out.push(`<pre class="code"${lang ? ` data-lang="${escapeHTML(lang)}"` : ""}><code>${code}</code></pre>`);
      continue;
    }
    // headings
    const hm = l.match(/^(#{2,4})\s+(.+)$/);
    if (hm) {
      const level = hm[1].length;
      out.push(`<h${level}>${renderInline(hm[2].trim())}</h${level}>`);
      i++;
      continue;
    }
    // blank line
    if (!l.trim()) { i++; continue; }
    // bullet list
    if (/^[-*]\s+/.test(l)) {
      const items: string[] = [];
      while (i < lines.length && /^[-*]\s+/.test(lines[i])) {
        items.push(lines[i].replace(/^[-*]\s+/, ""));
        i++;
      }
      out.push("<ul>" + items.map((it) => `<li>${renderInline(it)}</li>`).join("") + "</ul>");
      continue;
    }
    // numbered list
    if (/^\d+\.\s+/.test(l)) {
      const items: string[] = [];
      while (i < lines.length && /^\d+\.\s+/.test(lines[i])) {
        items.push(lines[i].replace(/^\d+\.\s+/, ""));
        i++;
      }
      out.push("<ol>" + items.map((it) => `<li>${renderInline(it)}</li>`).join("") + "</ol>");
      continue;
    }
    // paragraph: collect contiguous non-blank, non-heading, non-list lines
    const para: string[] = [l];
    i++;
    while (i < lines.length && lines[i].trim() && !/^(#{2,4}\s|[-*]\s|\d+\.\s|```)/.test(lines[i])) {
      para.push(lines[i]); i++;
    }
    out.push(`<p>${renderInline(para.join(" "))}</p>`);
  }
  return out.join("\n");
}

// ---------------------------------------------------------------------------
// Read state
// ---------------------------------------------------------------------------
type Module = {
  id: string;
  name?: string;
  "owner-role"?: string;
  purpose?: string;
  "in-scope"?: string[];
  "out-of-scope"?: string[];
};
type Process = {
  id: string;
  name?: string;
  purpose?: string;
  criticality?: number;
  "cross-refs"?: string[];
};

const visionMD = existsSync(join(stateDir, "vision")) ? readFileSync(join(stateDir, "vision"), "utf-8") : "";
const modules = (readYAMLFile(join(stateDir, "modules")) as Module[]) || [];
const coverage = (readYAMLFile(join(stateDir, "coverage")) as { [k: string]: string }) || {};
const processesByModule: { [modId: string]: Process[] } = {};
const procDir = join(stateDir, "processes");
if (existsSync(procDir)) {
  for (const f of readdirSync(procDir)) {
    const modId = f;
    const list = (readYAMLFile(join(procDir, f)) as Process[]) || [];
    processesByModule[modId] = list;
  }
}
const detailsDir = join(stateDir, "details");
const detailMD: { [procId: string]: string } = {};
if (existsSync(detailsDir)) {
  for (const f of readdirSync(detailsDir)) {
    if (!f.endsWith(".md")) continue;
    const procId = f.replace(/\.md$/, "");
    detailMD[procId] = readFileSync(join(detailsDir, f), "utf-8");
  }
}

// ---------------------------------------------------------------------------
// Render
// ---------------------------------------------------------------------------
function nodeAttr(kind: string, id: string): string {
  return `data-shape-node="${escapeHTML(kind + ":" + id)}"`;
}

function criticalityLabel(c?: number): string {
  if (c === 1) return '<span class="crit crit-1">critical</span>';
  if (c === 2) return '<span class="crit crit-2">important</span>';
  if (c === 3) return '<span class="crit crit-3">low</span>';
  return '<span class="crit crit-x">unscored</span>';
}

function coverageBadge(procId: string): string {
  const s = coverage[procId] || "todo";
  const cls = `cov cov-${s}`;
  return `<span class="${cls}">${s}</span>`;
}

const visionHTML = visionMD
  ? `<section class="vision" ${nodeAttr("vision", "")}>${renderMD(visionMD)}</section>`
  : `<section class="vision empty" ${nodeAttr("vision", "")}><p class="placeholder">No vision yet. Run the shape skill's <code>vision</code> phase.</p></section>`;

const modulesHTML = modules.length
  ? modules.map((m) => {
      const procs = processesByModule[m.id] || [];
      const procHTML = procs.map((p) => {
        const isDetailed = !!detailMD[p.id];
        const detailHTML = isDetailed ? renderMD(detailMD[p.id]) : "";
        return `
        <details class="process" ${nodeAttr("process", p.id)}${isDetailed ? " open" : ""}>
          <summary>
            <span class="proc-id">${escapeHTML(p.id)}</span>
            <span class="proc-name">${escapeHTML(p.name || "")}</span>
            ${criticalityLabel(p.criticality)}
            ${coverageBadge(p.id)}
          </summary>
          ${p.purpose ? `<p class="proc-purpose">${escapeHTML(p.purpose)}</p>` : ""}
          ${(p["cross-refs"] && p["cross-refs"].length)
            ? `<p class="proc-xrefs">cross-refs: ${p["cross-refs"].map((x) => `<code>${escapeHTML(x)}</code>`).join(", ")}</p>`
            : ""}
          ${isDetailed
            ? `<div class="detail" ${nodeAttr("detail", p.id)}>${detailHTML}</div>`
            : `<p class="placeholder">No detail yet.</p>`}
        </details>`;
      }).join("");
      const scopeBlock = (label: string, items?: string[]) =>
        items && items.length
          ? `<div class="scope-block"><h4>${label}</h4><ul>${items.map((s) => `<li>${escapeHTML(s)}</li>`).join("")}</ul></div>`
          : "";
      return `
      <details class="module" ${nodeAttr("module", m.id)} open>
        <summary>
          <span class="mod-id">${escapeHTML(m.id)}</span>
          <span class="mod-name">${escapeHTML(m.name || "")}</span>
          ${m["owner-role"] ? `<span class="mod-owner">${escapeHTML(m["owner-role"])}</span>` : ""}
        </summary>
        ${m.purpose ? `<p class="mod-purpose">${escapeHTML(m.purpose)}</p>` : ""}
        <div class="scope-grid">
          ${scopeBlock("In scope", m["in-scope"])}
          ${scopeBlock("Out of scope", m["out-of-scope"])}
        </div>
        <div class="processes">${procHTML || '<p class="placeholder">No processes yet.</p>'}</div>
      </details>`;
    }).join("")
  : '<p class="placeholder">No modules yet. Run the shape skill\'s <code>modules</code> phase.</p>';

const css = `
:root {
  --ink: #1a1a1a; --muted: #6b6b6b; --line: #d6d3cc; --bg: #faf8f3;
  --paper: #fff; --accent: #5a3e2a; --highlight: #fef7e0;
  --crit-1: #b33; --crit-2: #cc8a1a; --crit-3: #6b6b6b; --crit-x: #999;
  --cov-detailed: #2a7a2a; --cov-deferred: #cc8a1a; --cov-skipped: #999; --cov-todo: #888;
}
* { box-sizing: border-box; }
body { margin: 0; padding: 0; background: var(--bg); color: var(--ink); font: 16px/1.65 ui-serif, "Iowan Old Style", "Source Han Serif SC", "Songti SC", Georgia, serif; }
main { max-width: 960px; margin: 0 auto; padding: 40px 32px 96px; }
header.brief-header { border-bottom: 1px solid var(--line); padding-bottom: 16px; margin-bottom: 24px; }
header.brief-header h1 { margin: 0; font-size: 28px; letter-spacing: -0.01em; }
header.brief-header .meta { color: var(--muted); font-size: 13px; margin-top: 4px; }
section.vision { background: var(--paper); border: 1px solid var(--line); border-radius: 6px; padding: 24px 28px; margin-bottom: 24px; }
section.vision.empty { background: transparent; border: 1px dashed var(--line); }
section.vision h2, section.vision h3 { color: var(--accent); }
details.module { background: var(--paper); border: 1px solid var(--line); border-radius: 6px; margin: 16px 0; padding: 12px 20px; }
details.module > summary { cursor: pointer; padding: 4px 0; font-size: 18px; }
details.module > summary .mod-id { color: var(--muted); font-family: ui-monospace, monospace; margin-right: 12px; }
details.module > summary .mod-name { font-weight: 600; }
details.module > summary .mod-owner { color: var(--accent); font-size: 13px; margin-left: 12px; }
.mod-purpose { color: var(--muted); margin: 8px 0 16px; }
.scope-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 12px; }
.scope-block h4 { margin: 0 0 4px; font-size: 13px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.05em; }
.scope-block ul { margin: 0; padding-left: 18px; font-size: 14px; }
.processes { margin-top: 8px; }
details.process { border-left: 3px solid var(--line); padding: 8px 16px; margin: 6px 0; background: #fafaf7; border-radius: 0 4px 4px 0; }
details.process[open] { border-left-color: var(--accent); }
details.process > summary { cursor: pointer; padding: 2px 0; font-size: 15px; }
details.process > summary .proc-id { color: var(--muted); font-family: ui-monospace, monospace; margin-right: 8px; font-size: 13px; }
details.process > summary .proc-name { font-weight: 500; margin-right: 8px; }
.proc-purpose { color: var(--muted); font-size: 14px; margin: 4px 0; }
.proc-xrefs { font-size: 12px; color: var(--muted); margin: 4px 0; }
.detail { margin-top: 12px; padding-top: 12px; border-top: 1px solid var(--line); }
.detail h2, .detail h3, .detail h4 { color: var(--accent); margin-top: 16px; }
.detail h2 { font-size: 16px; }
.detail h3 { font-size: 14px; }
.detail code { background: #f0ece0; padding: 1px 4px; border-radius: 3px; font-size: 90%; }
pre.code { background: #f4f1e8; border: 1px solid var(--line); border-radius: 4px; padding: 12px; overflow-x: auto; font-size: 13px; }
.crit { font-size: 11px; padding: 1px 6px; border-radius: 3px; margin-left: 4px; }
.crit-1 { background: var(--crit-1); color: #fff; }
.crit-2 { background: var(--crit-2); color: #fff; }
.crit-3 { background: var(--crit-3); color: #fff; }
.crit-x { background: var(--crit-x); color: #fff; }
.cov { font-size: 11px; padding: 1px 6px; border-radius: 3px; margin-left: 4px; font-family: ui-monospace, monospace; }
.cov-detailed { background: var(--cov-detailed); color: #fff; }
.cov-deferred { background: var(--cov-deferred); color: #fff; }
.cov-skipped { background: var(--cov-skipped); color: #fff; }
.cov-todo { background: var(--cov-todo); color: #fff; }
.placeholder { color: var(--muted); font-style: italic; font-size: 14px; }
code { background: #f0ece0; padding: 1px 4px; border-radius: 3px; font-family: ui-monospace, monospace; font-size: 90%; }
`;

const html = `<!doctype html>
<html lang="zh-CN">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Brief</title>
<style>${css}</style>
</head>
<body>
<main>
  <header class="brief-header">
    <h1>Brief</h1>
    <div class="meta">canonical state under <code>${escapeHTML(execDir)}/state/</code> · rendered ${new Date().toISOString()}</div>
  </header>
  ${visionHTML}
  ${modulesHTML}
</main>
</body>
</html>
`;

const outPath = join(outDir, "index.html");
writeFileSync(outPath, html);
console.log(`render: wrote ${outPath} (${html.length} bytes)`);
console.log(`  modules:   ${modules.length}`);
console.log(`  processes: ${Object.values(processesByModule).reduce((a, b) => a + b.length, 0)}`);
console.log(`  details:   ${Object.keys(detailMD).length}`);
