#!/usr/bin/env bun
//
// preview-server <output-dir> <exec-dir> [--port=N]
//
// Serves files from <output-dir>. Injects preview-overlay.js into every HTML
// response so the user can annotate elements in the browser. Pending
// annotations live as a draft on the server, NOT in the user's browser, so:
//   - they survive tab close
//   - they're visible to every browser hitting the same server (refresh-based sync)
//   - the agent can read them as a regular state KV before they're committed
//
// The flow is two-stage:
//
//   draft  →  ${EXEC}/execution-state/feedback-draft.jsonl   (mutable)
//   commit →  ${EXEC}/execution-state/feedback-inbox.jsonl   (append-only, agent reads)
//          +  ${EXEC}/input.md               (new input-NNN entry)
//
// Endpoints (annotation flow):
//
//   GET    /draft               → { feedback: Comment[] }
//   POST   /draft/feedback      body: { url, selector, comment }
//                               → { ok, id, count } ; appends to feedback-draft
//   DELETE /draft/feedback/:id  → { ok, count }     ; rewrites feedback-draft minus :id
//   DELETE /draft               → { ok }            ; clears all drafts
//   POST   /commit              → { ok, accepted, input_id }
//                                 atomic: rename draft → temp → drain into inbox →
//                                 append input.md entry → unlink temp.
//

import { readFileSync, writeFileSync, existsSync, statSync, appendFileSync, mkdirSync, renameSync, unlinkSync } from "fs";
import { join, extname, dirname, resolve } from "path";

const args = process.argv.slice(2);
const positional = args.filter((a) => !a.startsWith("--"));
const portArg = args.find((a) => a.startsWith("--port="));
const requestedPort = portArg ? parseInt(portArg.slice(7), 10) : 0;

if (positional.length < 2) {
  console.error("Usage: preview-server <output-dir> <exec-dir> [--port=N]");
  process.exit(1);
}

const root = resolve(positional[0]);
const execDir = resolve(positional[1]);
if (!existsSync(root) || !statSync(root).isDirectory()) {
  console.error(`output-dir does not exist or is not a directory: ${root}`);
  process.exit(1);
}
if (!existsSync(execDir) || !statSync(execDir).isDirectory()) {
  console.error(`exec-dir does not exist or is not a directory: ${execDir}`);
  process.exit(1);
}

const overlayPath = join(import.meta.dir, "preview-overlay.js");
// Re-read overlay JS from disk on every request so edits during development
// take effect with a browser refresh — no server restart needed.
const readOverlay = (): string => readFileSync(overlayPath, "utf-8");

const inputMdPath = join(execDir, "input.md");
const feedbackInbox = join(execDir, "execution-state", "feedback-inbox.jsonl");
const feedbackDraft = join(execDir, "execution-state", "feedback-draft.jsonl");

mkdirSync(join(execDir, "execution-state"), { recursive: true });

// ---------- mime ----------
function mimeFor(p: string): string {
  switch (extname(p).toLowerCase()) {
    case ".html": return "text/html; charset=utf-8";
    case ".css": return "text/css; charset=utf-8";
    case ".js": case ".mjs": return "application/javascript; charset=utf-8";
    case ".json": return "application/json";
    case ".png": return "image/png";
    case ".jpg": case ".jpeg": return "image/jpeg";
    case ".svg": return "image/svg+xml";
    case ".webp": return "image/webp";
    case ".gif": return "image/gif";
    case ".woff": return "font/woff";
    case ".woff2": return "font/woff2";
    case ".pdf": return "application/pdf";
    default: return "application/octet-stream";
  }
}

function injectOverlay(html: string): string {
  const tag = `\n<script>${readOverlay()}</script>\n`;
  if (html.includes("</body>")) return html.replace("</body>", tag + "</body>");
  return html + tag;
}

// ---------- helpers ----------
function isoNow(): string {
  const d = new Date();
  const pad = (n: number) => String(n).padStart(2, "0");
  return `${d.getUTCFullYear()}-${pad(d.getUTCMonth() + 1)}-${pad(d.getUTCDate())}T${pad(d.getUTCHours())}:${pad(d.getUTCMinutes())}:${pad(d.getUTCSeconds())}Z`;
}

function shortId(): string {
  // 6 chars from [0-9a-z] — collision-resistant enough at the draft scale.
  const a = "0123456789abcdefghijklmnopqrstuvwxyz";
  let s = "";
  for (let i = 0; i < 6; i++) s += a[Math.floor(Math.random() * a.length)];
  return s;
}

function nextInputNum(): number {
  if (!existsSync(inputMdPath)) return 1;
  const content = readFileSync(inputMdPath, "utf-8");
  const matches = [...content.matchAll(/^## input-(\d+)\b/gm)];
  if (matches.length === 0) return 1;
  return Math.max(...matches.map((m) => parseInt(m[1], 10))) + 1;
}

function appendInputEntry(title: string, body: string): string {
  const n = nextInputNum();
  const id = `input-${String(n).padStart(3, "0")}`;
  const sep = existsSync(inputMdPath) && readFileSync(inputMdPath, "utf-8").trim().length > 0
    ? "\n\n---\n\n"
    : "";
  const ts = isoNow();
  const entry = `${sep}## ${id} @ ${ts} — ${title}\n\n${body}\n`;
  appendFileSync(inputMdPath, entry);
  return id;
}

function appendJsonl(p: string, obj: unknown): void {
  mkdirSync(dirname(p), { recursive: true });
  appendFileSync(p, JSON.stringify(obj) + "\n");
}

function readJsonl<T>(p: string): T[] {
  if (!existsSync(p)) return [];
  const text = readFileSync(p, "utf-8");
  const out: T[] = [];
  for (const line of text.split("\n")) {
    const trimmed = line.trim();
    if (!trimmed) continue;
    try { out.push(JSON.parse(trimmed) as T); } catch { /* skip malformed */ }
  }
  return out;
}

function writeJsonl(p: string, rows: unknown[]): void {
  mkdirSync(dirname(p), { recursive: true });
  const body = rows.length === 0 ? "" : rows.map((r) => JSON.stringify(r)).join("\n") + "\n";
  writeFileSync(p, body);
}

async function readJsonBody(req: Request): Promise<any | null> {
  try { return await req.json(); } catch { return null; }
}

// ---------- mutex for draft mutations ----------
// Bun.serve handles requests concurrently. Draft writes are read-modify-write
// (delete rewrites the file, commit renames it) — serialize them.
let chain: Promise<unknown> = Promise.resolve();
function serial<T>(fn: () => Promise<T> | T): Promise<T> {
  const next = chain.then(() => fn());
  chain = next.then(() => {}, () => {});
  return next;
}

// ---------- types ----------
type Comment = {
  id: string;
  ts: string;
  url: string;
  selector: string;
  comment: string;
};

// ---------- handlers ----------
function handleGetDraft(): Response {
  const feedback = readJsonl<Comment>(feedbackDraft);
  return Response.json({ feedback });
}

async function handlePostDraftFeedback(req: Request): Promise<Response> {
  const body = await readJsonBody(req);
  if (!body || typeof body.url !== "string" || typeof body.selector !== "string" || typeof body.comment !== "string") {
    return new Response("bad request", { status: 400 });
  }
  const comment = body.comment.trim();
  if (!comment) return new Response("empty comment", { status: 400 });
  return serial(() => {
    const entry: Comment = {
      id: shortId(),
      ts: isoNow(),
      url: body.url,
      selector: body.selector,
      comment,
    };
    appendJsonl(feedbackDraft, entry);
    const count = readJsonl<Comment>(feedbackDraft).length;
    return Response.json({ ok: true, id: entry.id, count });
  });
}

function handleDeleteDraftFeedback(id: string): Promise<Response> {
  return serial(() => {
    const rows = readJsonl<Comment>(feedbackDraft);
    const next = rows.filter((r) => r.id !== id);
    if (next.length === rows.length) {
      return new Response("not found", { status: 404 });
    }
    writeJsonl(feedbackDraft, next);
    return Response.json({ ok: true, count: next.length });
  });
}

function handleDeleteDraftAll(): Promise<Response> {
  return serial(() => {
    if (existsSync(feedbackDraft)) writeJsonl(feedbackDraft, []);
    return Response.json({ ok: true });
  });
}

function handleCommit(): Promise<Response> {
  return serial(() => {
    if (!existsSync(feedbackDraft)) {
      return Response.json({ ok: true, accepted: 0, input_id: null });
    }
    // Atomic rename to a stable temp file; new POST /draft writes meanwhile go
    // to a fresh feedback-draft (created by appendFileSync) and survive.
    const ts = Date.now();
    const stage = `${feedbackDraft}.committing-${ts}`;
    renameSync(feedbackDraft, stage);

    const rows = readJsonl<Comment>(stage);
    if (rows.length === 0) {
      try { unlinkSync(stage); } catch {}
      return Response.json({ ok: true, accepted: 0, input_id: null });
    }
    // Append each into the inbox (drop the draft `id`; inbox doesn't need it).
    for (const r of rows) {
      appendJsonl(feedbackInbox, { ts: r.ts, url: r.url, selector: r.selector, comment: r.comment });
    }
    const inputId = appendInputEntry(
      `Live annotations (${rows.length})`,
      `User committed ${rows.length} annotation(s) via the preview overlay. ` +
        "Read the feedback-inbox blob (state.yaml key `feedback-inbox`) for the entries — each " +
        "carries (ts, url, selector, comment). Drain via the `live-annotate` skill's procedure: " +
        "resolve (url, selector) to the calling application's source-of-truth (design → the HTML " +
        "in output-dir; shape → a state.yaml key / by-ref blob, then re-render; other applications " +
        "define their own resolver), apply the edit, append to feedback-resolved, remove the " +
        "consumed line from feedback-inbox, and advance the input cursor."
    );
    try { unlinkSync(stage); } catch {}
    return Response.json({ ok: true, accepted: rows.length, input_id: inputId });
  });
}

// ---------- server ----------
const server = Bun.serve({
  port: requestedPort,
  hostname: "0.0.0.0",
  async fetch(req) {
    const url = new URL(req.url);
    const pathname = url.pathname;
    const method = req.method;

    // --- draft / commit (annotation flow) ---
    if (method === "GET" && pathname === "/draft") return handleGetDraft();
    if (method === "POST" && pathname === "/draft/feedback") return handlePostDraftFeedback(req);
    if (method === "DELETE" && pathname.startsWith("/draft/feedback/")) {
      const id = pathname.slice("/draft/feedback/".length);
      if (!id) return new Response("bad request", { status: 400 });
      return handleDeleteDraftFeedback(id);
    }
    if (method === "DELETE" && pathname === "/draft") return handleDeleteDraftAll();
    if (method === "POST" && pathname === "/commit") return handleCommit();

    // --- overlay script direct access ---
    if (pathname === "/__overlay.js") {
      return new Response(readOverlay(), { headers: { "Content-Type": "application/javascript; charset=utf-8" } });
    }

    // --- static files from output-dir ---
    if (method !== "GET" && method !== "HEAD") {
      return new Response("method not allowed", { status: 405 });
    }

    let relPath = decodeURIComponent(pathname.replace(/^\/+/, ""));
    if (relPath === "" || relPath.endsWith("/")) relPath += "index.html";
    const absPath = resolve(root, relPath);
    if (!absPath.startsWith(root)) return new Response("forbidden", { status: 403 });

    let targetPath = absPath;
    if (!existsSync(targetPath)) return new Response("not found", { status: 404 });
    if (statSync(targetPath).isDirectory()) {
      targetPath = join(targetPath, "index.html");
      if (!existsSync(targetPath)) return new Response("not found", { status: 404 });
    }

    if (extname(targetPath).toLowerCase() === ".html") {
      const html = readFileSync(targetPath, "utf-8");
      return new Response(injectOverlay(html), { headers: { "Content-Type": "text/html; charset=utf-8" } });
    }

    return new Response(Bun.file(targetPath), { headers: { "Content-Type": mimeFor(targetPath) } });
  },
});

console.log(`preview-server: listening on 0.0.0.0:${server.port}`);
console.log(`  local:    http://localhost:${server.port}`);
console.log(`  LAN:      http://<this-host-ip>:${server.port}  (bound to 0.0.0.0 — reachable from other machines)`);
console.log(`  serving:  ${root}`);
console.log(`  exec dir: ${execDir}`);
console.log(`  draft:    ${feedbackDraft}`);
console.log(`  inbox:    ${feedbackInbox} (filled on POST /commit)`);
